# 复制为 application-local.yml（与 backend 目录同级，勿提交 Git）
# 用于覆盖 MySQL 账号密码，解决登录 500（数据库连接失败）

spring:
  datasource:
    url: jdbc:mysql://localhost:3306/grms?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
    username: root
    password: 你的MySQL密码
